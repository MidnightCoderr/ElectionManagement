# ===================================
# Election Management System - Environment Configuration
# ===================================

# Node Environment
NODE_ENV=development

# Backend Server
BACKEND_PORT=3000
BACKEND_HOST=localhost

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=election_db
POSTGRES_USER=election_admin
POSTGRES_PASSWORD=changeme_secure_password

# MongoDB
MONGODB_URI=mongodb://localhost:27017/election_logs
MONGODB_USER=mongo_admin
MONGODB_PASSWORD=changeme_mongo_password

# JWT Authentication
JWT_SECRET=changeme_random_256bit_secret_key_here
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=changeme_refresh_secret_key
JWT_REFRESH_EXPIRY=7d

# Hyperledger Fabric
FABRIC_NETWORK_NAME=election-network
FABRIC_CHANNEL_NAME=election-channel
FABRIC_CHAINCODE_NAME=voting
FABRIC_ORG_NAME=ElectionCommission
FABRIC_MSP_ID=ElectionCommissionMSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_ORDERER_ENDPOINT=localhost:7050
FABRIC_CA_ENDPOINT=localhost:7054
FABRIC_WALLET_PATH=./wallet
FABRIC_CONNECTION_PROFILE_PATH=./blockchain/network/connection-profile.json

# Encryption
AES_ENCRYPTION_KEY=changeme_32_character_aes_key!!
ENCRYPTION_ALGORITHM=aes-256-gcm

# MQTT for IoT Terminals
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=iot_client
MQTT_PASSWORD=changeme_mqtt_password
MQTT_TOPIC_AUTH=election/auth
MQTT_TOPIC_VOTE=election/vote

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# ML Analytics
PYTHON_ML_SERVICE_URL=http://localhost:5000
ML_MODEL_PATH=./ml-analytics/src/models/voting_patterns.pkl
ANOMALY_THRESHOLD=0.85

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=changeme_email_password
EMAIL_FROM=noreply@electionsystem.org

# SMS Notifications (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:3003

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/application.log

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Public Blockchain (for audit snapshots)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_project_id
ETHEREUM_PRIVATE_KEY=changeme_ethereum_private_key
SNAPSHOT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# IoT Security
ALLOWED_MAC_ADDRESSES=AA:BB:CC:DD:EE:FF,11:22:33:44:55:66
IOT_DEVICE_REGISTRATION_KEY=changeme_device_registration_key

# Frontend URLs
VOTER_UI_URL=http://localhost:3001
OBSERVER_DASHBOARD_URL=http://localhost:3002
ADMIN_PORTAL_URL=http://localhost:3003

# WebSocket
WEBSOCKET_PORT=3100

# Feature Flags
ENABLE_ZKP=true
ENABLE_OFFLINE_CACHING=true
ENABLE_ML_FRAUD_DETECTION=true
ENABLE_PUBLIC_AUDIT_SNAPSHOTS=true
ENABLE_MULTI_LANGUAGE=true
